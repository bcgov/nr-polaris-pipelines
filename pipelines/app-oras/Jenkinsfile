@Library('polaris@v2.0.0')
import ca.bc.gov.nrids.polaris.Podman
import ca.bc.gov.nrids.polaris.BrokerIntention
import ca.bc.gov.nrids.polaris.Vault
import ca.bc.gov.nrids.polaris.JenkinsUtil

def intention
def podman

/*
 * Pipeline parameters consumed by this Jenkinsfile:
 * - projectVersion: Display/build package version and deployment metadata version.
 * - envLong: Target environment (dev, test, production).
 * - deployUrl: ORAS reference for deployment configuration package.
 * - artifactUrl: ORAS reference for application package.
 * - artifactSrc: Artifact registry type (github or artifactory).
 * - artifactSha256: Expected SHA256 digest for deploy/app ORAS content.
 * - githubUser: Username for GHCR login.
 * - githubToken: Token for GHCR login.
 * - catalogInfoPath: Relative path in deploy package to catalog-info.yaml (default: .).
 * - eventProvider: Event source/provider name sent to Broker.
 * - githubRunId: External workflow run id used in trigger metadata.
 * - triggerUrl: External workflow/job URL used in trigger metadata.
 * - ansibleCollectionBranchTag: Polaris collection tag/branch (default: v3.5.0).
 * - deploymentApprover: Username/email recorded as deployment approver (default: github@internal).
 * - intentionId: Source intention id recorded in deployment metadata.
 * - sourceRoot: Application source root path (default: .).
 * - brokerJwt: Broker JWT used to open deployment intention.
 * - devInventoryPath: Inventory file path for dev deployments.
 * - testInventoryPath: Inventory file path for test deployments.
 * - prodInventoryPath: Inventory file path for production deployments.
 *
 * Project/component are derived from ${catalogInfoPath}/catalog-info.yaml:
 * - project: spec.system
 * - component: metadata.name
 */

pipeline {
    agent none
    stages {
        stage('Initialize') {
            agent {
                label Podman.AGENT_LABEL_APP
            }
            steps {
                script {
                    // Set the build display name
                    currentBuild.displayName = "#${BUILD_NUMBER} - ${params.projectVersion} - ${params.envLong}"

                    // Clean up any existing files in the downloads directory and create necessary subdirectories
                    sh 'rm -rf downloads ; mkdir -p downloads/app ; mkdir -p downloads/deploy'
                }
            }
        }
        stage('Banner') {
            steps {
	            script {
                    echo "==================="
                    echo "NR Polaris Pipeline"
                    echo "==================="
                    echo ""
                    echo "Standard on-premise ORAS (OCI Registry As Storage) application deployment pipeline"
                    echo ""
                    echo "Jenkinsfile: https://github.com/bcgov-nr/polaris-pipelines/blob/main/pipelines/nodejs"
                    echo "Ansible Polaris collection: https://github.com/bcgov/nr-polaris-collection"
                    echo ""
                    echo "Developers are expected to review the documentation of all roles used by their Ansible playbook file."
                }
            }
        }
        stage('Download deployment configuration package') {
            agent {
                label Podman.AGENT_LABEL_APP
            }
            environment {
                DEPLOY_URL = "${params.deployUrl}"
                DEPLOY_SHA256 = "${params.artifactSha256}"
                GITHUB_USER = "${params.githubUser}"
                GITHUB_TOKEN = "${params.githubToken}"
            }
            steps {
                script {
                    echo 'NR POLARIS - Download deployment configuration package'
                    sh 'echo ${GITHUB_TOKEN} | /sw_ux/bin/oras login ghcr.io -u ${GITHUB_USER} --password-stdin'
                    def deploy_sha256 = sh(
                        returnStdout: true,
                        script: '''
                            cd downloads/deploy
                            output=$(/sw_ux/bin/oras pull ${DEPLOY_URL} --format go-template='{{toRawJson .}}' > ./oras_output.json 2>/dev/null)
                            sha256=$(jq -r '.files[] | select(.annotations["org.opencontainers.image.title"] == "dist") | .digest | split(":")[1]' ./oras_output.json)
                            echo "${sha256}"
                            rm -f ./oras_output.json
                        '''
                    )

                    if (deploy_sha256.trim() != DEPLOY_SHA256.trim()) {
                        error "Checksum verification failed!"
                    } else {
                        echo "Checksum verification passed!"
                    }
                    sh 'ls -l downloads/deploy'
                }
            }
        }

        stage('Download app package') {
            agent {
                label Podman.AGENT_LABEL_APP
            }
            environment {
                ARTIFACT_URL = "${params.artifactUrl}"
                ARTIFACT_SRC =" ${params.artifactSrc}"
                ARTIFACT_SHA256 = "${params.artifactSha256}"
                GITHUB_USER = "${params.githubUser}"
                GITHUB_TOKEN = "${params.githubToken}"
            }
            steps {
                script {
                    echo 'NR POLARIS - Download app package'

                    if (ARTIFACT_SRC == 'github') {
                        sh 'echo ${GITHUB_TOKEN} | /sw_ux/bin/oras login ghcr.io -u ${GITHUB_USER} --password-stdin'
                    } else if (ARTIFACT_SRC == 'artifactory') {
                        sh 'echo ${ARTIFACTORY_PASSWORD} | /sw_ux/bin/oras login ${ARTIFACTORY_URL} -u ${ARTIFACTORY_USERNAME} --password-stdin'
                    } else {
                        error "Invalid artifact source specified: ${ARTIFACT_SRC}"
                    }

                    def download_sha256 = sh(
                        returnStdout: true,
                        script: '''
                            cd downloads/app
                            output=$(/sw_ux/bin/oras pull ${ARTIFACT_URL} --format go-template='{{toRawJson .}}' > ./oras_output.json 2>/dev/null)
                            sha256=$(jq -r '.files[] | select(.annotations["org.opencontainers.image.title"] == "dist") | .digest | split(":")[1]' ./oras_output.json)
                            echo "${sha256}"
                            rm -f ./oras_output.json
                        '''
                    )

                    if (download_sha256.trim() != ARTIFACT_SHA256.trim()) {
                        error "Checksum verification failed!"
                    } else {
                        echo "Checksum verification passed!"
                    }
                    sh 'ls -l downloads/app'
                }
            }
        }
        stage('Checkout INFRA dev-all-in-one') {
            agent {
                label Podman.AGENT_LABEL_APP
            }
            steps {
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: "release/1.0.0"]],
                    doGenerateSubmoduleConfigurations: false,
                    extensions: [
                        [$class: 'RelativeTargetDirectory', relativeTargetDir: "infra"]
                    ],
                    submoduleCfg: [],
                    userRemoteConfigs: [
                        [
                            credentialsId: 'ci-user',
                            url: "https://bwa.nrs.gov.bc.ca/int/stash/scm/infra/dev-all-in-one.git"
                        ]
                    ]
                ])
            }
        }
        stage('Deploy to environment') {
            agent {
                label Podman.AGENT_LABEL_APP
            }
            environment {
                CATALOG_INFO_PATH = "${params.catalogInfoPath != null && params.catalogInfoPath != "" ? params.catalogInfoPath : "."}"
                ENV_LONG = "${params.envLong}"
                EVENT_PROVIDER = "${params.eventProvider}"
                GITHUB_RUNID= "${params.githubRunId}"
                TRIGGER_URL = "${params.triggerUrl}"
                HTTP_PROXY = "${params.envLong == 'production' ? 'http://forwardproxy.nrs.bcgov:23128' : 'http://test-forwardproxy.nrs.bcgov:23128'}"
                ANSIBLE_COLLECTION_VERSION = "${params.ansibleCollectionBranchTag != null && params.ansibleCollectionBranchTag != "" ? ",${params.ansibleCollectionBranchTag}" : ",v3.5.0"}"
                PODMAN_ANSIBLE_COLLECTION_URL = "github.com/bcgov/nr-polaris-collection.git#polaris/deploy${env.ANSIBLE_COLLECTION_VERSION}"
                PODMAN_ANSIBLE_COLLECTION_PATH = "./collections/ansible_collections"
                GIT_CREDS = credentials('ci-user')
                GIT_CREDS_USR = GIT_CREDS_USR.replaceFirst('@', '%40')
                CONFIG_ROLE_ID = credentials('knox-jenkins-jenkins-apps-prod-role-id')
                AUTHFILE = "auth.json"
                DEPLOYMENT_APPROVER = "${params.deploymentApprover != null && params.deploymentApprover != "" ? params.deploymentApprover : "github@internal"}"
                INTENTION_ID = "${params.intentionId}"
                PODMAN_ARTIFACT_SHA256 = "${params.artifactSha256}"
                PODMAN_PROJECT_VERSION = "${params.projectVersion}"
                PODMAN_PLAYBOOKS_PATH = "downloads/deploy/${env.CATALOG_INFO_PATH}/playbooks"
            }
            steps {
                script {
                    try {
                        echo "Deploy to ${env.ENV_LONG} environment"
                        def catalogInfo = readYaml file: "downloads/deploy/${env.CATALOG_INFO_PATH}/catalog-info.yaml"
                        env.PROJECT = catalogInfo.spec.system
                        env.COMPONENT = catalogInfo.metadata.name
                        env.ENV_SHORT = JenkinsUtil.convertLongEnvToShort("${params.envLong}")
                        def triggerId = "${env.COMPONENT} ${env.GITHUB_RUNID}"
                        intention = new BrokerIntention("${params.brokerJwt}", readJSON(file: "app/.jenkins/${env.COMPONENT}-deployment-intention.json"))
                        if (env.ENV_SHORT == 'dev') {
                            env.PODMAN_ANSIBLE_INVENTORY_PATH = params.devInventoryPath
                        } else if (env.ENV_SHORT == 'test') {
                            env.PODMAN_ANSIBLE_INVENTORY_PATH = params.testInventoryPath
                        } else if (env.ENV_SHORT == 'prod') {
                            env.PODMAN_ANSIBLE_INVENTORY_PATH = params.prodInventoryPath
                        }
                        intention.setEventDetails(
                            userName: env.DEPLOYMENT_APPROVER,
                            url: env.BUILD_URL,
                            provider: env.EVENT_PROVIDER,
                            triggerId: triggerId,
                            triggerUrl: env.TRIGGER_URL,
                            environment: env.ENV_LONG,
                            packageInstallationVersion: env.PODMAN_PROJECT_VERSION,
                            packageInstallationSourceIntention: env.INTENTION_ID
                        )
                        intention.open()
                        intention.startAction("login")
                        def vaultToken = intention.provisionToken("login", CONFIG_ROLE_ID)
                        def vault = new Vault(vaultToken)
                        vault.readToObject("apps/data/prod/jenkins/jenkins-apps/jdk_cacerts_pass", env)
                        vault.readToObject("apps/data/prod/jenkins/jenkins-apps/artifactory", env)
                        vault.readToObject("apps/data/prod/jenkins/jenkins-apps/cdua", env)
                        env.PODMAN_BUILD_NUMBER = env.BUILD_NUMBER
                        env.PODMAN_BUILD_URL = env.BUILD_URL
                        def appRoleId = null
                        try {
                            withCredentials([string(credentialsId: "knox-${env.PROJECT}-${env.COMPONENT}-${env.ENV_SHORT}-role-id", variable: 'APP_ROLE_ID')]) {
                                appRoleId = env.APP_ROLE_ID
                            }
                        } catch (Exception e) {
                            echo "Provisioning without AppRole RoleID (Jenkins credential: knox-${env.PROJECT}-${env.COMPONENT}-${env.ENV_SHORT}-role-id)"
                            echo "Broker Account must be configured with 'Require RoleId: No'"
                        }
                        intention.startAction("configure")
                        def vaultAppToken = intention.provisionToken("configure", appRoleId)
                        def vaultApp = new Vault(vaultAppToken)
                        vaultApp.readToObject("apps/data/${env.ENV_SHORT}/${env.PROJECT}/${env.COMPONENT}/${env.ENV_LONG}", env, keyTransform: { key -> 'PODMAN_' + key })
                        vaultApp.revokeToken()
                        intention.endAction("configure")
                        intention.startAction("install")
                        intention.openResponse.actions.each { key, value ->
                            env."ACTION_TOKEN_${key.toUpperCase()}" = "${value.token}"
                        }
                        podman = new Podman(this)
                        def appMountPath = "\$(pwd)/downloads/deploy/${env.CATALOG_INFO_PATH}/playbooks"
                        podman.login(authfile: "${env.AUTHFILE}", options: "-u ${env.REGISTRY_USERNAME} -p ${env.REGISTRY_PASSWORD}")
                        podman.run("willhallonline/ansible:2.16-alpine-3.21",
                            authfile: "${env.AUTHFILE}",
                            options: "-v \$(pwd):/ansible -e PODMAN_*",
                            command: '/bin/sh -c "git config --global advice.detachedHead false && ansible-galaxy collection install git+https://${PODMAN_ANSIBLE_COLLECTION_URL} -p ${PODMAN_ANSIBLE_COLLECTION_PATH}"')
                        podman.run("willhallonline/ansible:2.16-alpine-3.21",
                            authfile: "${env.AUTHFILE}",
                            options: "-v \$(pwd)/collections:/ansible/app/playbooks/collections \
                                -v ${appMountPath}:/ansible/app \
                                -v \$(pwd)/infra/inventory:/ansible/inventory \
                                -v \$(pwd)/files/ansible/ansible.cfg:/etc/ansible/ansible.cfg \
                                -v \$(pwd)/downloads/app:/ansible/downloads \
                                -e PODMAN_* -e ACTION_TOKEN_* -e COMPONENT*",
                            command: 'ansible-playbook -i inventory/${PODMAN_ANSIBLE_INVENTORY_PATH} \
                                app/playbooks/playbook.yaml -e "env_vars=${ENV_SHORT}" -e "proxy_env=${ENV_SHORT}"')
                        podman.logout(authfile: "${env.AUTHFILE}")
                        intention.endAction("install")
                        vault.revokeToken()
                        intention.endAction("login")
                        println intention.close(true)
                        intention = null
                    } catch (IllegalStateException ex) {
                        echo "IllegalStateException occurred: $ex"
                        currentBuild.result = 'FAILURE'
                        error('Quitting')
                    } catch (IllegalArgumentException ex) {
                        echo "IllegalArgumentException occurred: $ex"
                        currentBuild.result = 'FAILURE'
                        error('Quitting')
                    } catch (Exception ex) {
                        echo "Other exception occurred: $ex"
                        currentBuild.result = 'FAILURE'
                        error('Quitting')
                    }
                }
            }
        }
    }
    post {
        unstable {
            node(Podman.AGENT_LABEL_APP) {
                script {
                    if (intention) {
                        println intention.close(false)
                    }
                }
            }
        }
        failure {
            node(Podman.AGENT_LABEL_APP) {
                script {
                    if (intention) {
                        println intention.close(false)
                    }
                }
            }
        }
        aborted {
            node(Podman.AGENT_LABEL_APP) {
                script {
                    if (intention) {
                        println  intention.close(false)
                    }
                }
            }
        }
        always {
            node(Podman.AGENT_LABEL_APP) {
                cleanWs(
                    cleanWhenAborted: true,
                    cleanWhenFailure: false,
                    cleanWhenSuccess: true,
                    cleanWhenUnstable: false,
                    deleteDirs: true
                )
            }
        }
    }
}
